async def determine_platform_fee(task: str, winning_bid: float, quality_score: int) -> float:
    """LLM determines a fair platform fee based on task context."""
    prompt = f"""
You are the NeuralMarket Treasury. Determine a fair platform fee for this completed task.
Task: "{task[:100]}"
Winning Bid: ${winning_bid:.6f} USDC
Quality Score: {quality_score}/100

Consider:
- Higher quality work should incur a lower fee (reward excellence).
- The fee should be between 5% and 15% of the winning bid.
- Minimum fee: $0.00005 USDC.

Output ONLY a JSON object: {{"fee_usdc": 0.0001, "reasoning": "Brief explanation"}}
"""
    resp = aiml_client.chat.completions.create(
        model=ECONOMIST_MODEL,
        messages=[{"role": "user", "content": prompt}],
        temperature=0.3,
    )
    try:
        data = local_parse_json(resp.choices[0].message.content)
        fee = float(data.get("fee_usdc", 0.0001))
        return max(0.00005, min(fee, winning_bid * 0.15))
    except Exception:
        return 0.0001


