def analyze_weak_areas(agent: Dict) -> str:
    journal = agent.get("skill_journal", [])
    if not journal:
        return "unknown (insufficient data)"
    failures = [entry for entry in journal if entry.get("result") == "failure"]
    return f"Had {len(failures)} failures out of {len(journal)} attempts."

async def execute_synthetic_task(agent_name: str, agent: Dict, task: str) -> str:
    try:
        async with aiohttp.ClientSession() as session:
            result = await call_agent(
                session=session,
                agent_name=agent_name,
                agent=agent,
                prompt=f"Training task (self-improvement): {task}"
            )
            return "success" if result.get("status") == "success" else "failure"
    except:
        return "failure"

async def refine_system_prompt(agent_name: str, agent: Dict):
    prompt = f"""
    You are {agent_name}. Based on your recent performance journal:
    {json.dumps(agent.get('skill_journal', [])[-5:])}
    
    Write a new, improved system prompt for yourself that will help you perform better.
    Output only the new system prompt as a single string.
    """
    resp = aiml_client.chat.completions.create(
        model=AGENT_NEGOTIATION_MODEL,
        messages=[{"role": "user", "content": prompt}],
        temperature=0.4,
    )
    agent["system_prompt"] = resp.choices[0].message.content.strip()
    print(f"📈 Agent {agent_name} refined system prompt via curriculum learning.")

async def curriculum_learning_background():
    def local_parse_json(text):
        try:
            import json
            text = text.strip().replace("```json", "").replace("```", "").strip()
            start, end = text.find("{"), text.rfind("}") + 1
            if start != -1 and end > start:
                text = text[start:end]
            return json.loads(text)
        except:
            return {}

    while True:
        try:
            past = await database.get_all_transactions()
            if len(past) < 5:
                await asyncio.sleep(3600)
                continue
            
            for agent_name, agent in AGENTS.items():
                weak_areas = analyze_weak_areas(agent)
                curriculum_prompt = f"""
                You are a Curriculum Agent. Generate 3 challenging tasks specifically designed to improve
                an AI agent with the following profile:
                
                Agent: {agent_name}
                Capabilities: {agent['capabilities']}
                Weak areas: {weak_areas}
                Past performance: {json.dumps(agent.get('skill_journal', [])[-5:])}
                
                Output JSON with an array of tasks: {{"tasks": ["task1", "task2", "task3"]}}
                """
                resp = aiml_client.chat.completions.create(
                    model=CURRICULUM_MODEL,
                    messages=[{"role": "user", "content": curriculum_prompt}],
                    temperature=0.8,
                )
                try:
                    data = local_parse_json(resp.choices[0].message.content)
                    tasks = data.get("tasks", [])
                    for task in tasks[:2]:
                        if not isinstance(task, str):
                            continue
                        result = await execute_synthetic_task(agent_name, agent, task)
                        agent["skill_journal"].append({"task": task[:50], "result": result})
                        if len(agent["skill_journal"]) % 3 == 0:
                            await refine_system_prompt(agent_name, agent)
                except Exception as e:
                    print(f"Curriculum learning error for {agent_name}: {e}")
        except Exception as e:
            print(f"Curriculum background error: {e}")
        await asyncio.sleep(7200)

