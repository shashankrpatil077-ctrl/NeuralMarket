@app.post("/run_elite_loop")
async def run_elite_loop(request: TaskRequest):
    orchestrator_id = os.getenv("ORCHESTRATOR_WALLET_ID")
    treasury_address = os.getenv("TREASURY_ADDRESS")
    
    await sse_queue.put({
        "event": "task_received",
        "task": request.description,
        "max_budget": request.max_budget,
        "timestamp": datetime.now().isoformat()
    })
    
    # Phase 1: Orchestrator Analysis (Upgraded Autonomous)
    # ----------------------------------------------------------
    try:
        base_price_hint = economic_forecast.get("recommended_base_price", 0.0015)
        resp = aiml_client.chat.completions.create(
            model=ORCHESTRATOR_MODEL,
            messages=[
                {"role": "system", "content": "You are the NeuralMarket Chief Economist. Respond ONLY with valid JSON."},
                {"role": "user", "content": (
                    f"You are the NeuralMarket Chief Economist. Analyze this task deeply.\n\n"
                    f"Task: \"{request.description}\"\n"
                    f"User Max Budget: ${request.max_budget} USDC\n"
                    f"Market Hint: ${base_price_hint:.6f} USDC\n\n"
                    f"Step 1: Deconstruct the task. What core actions are required?\n"
                    f"Step 2: Rate complexity 1-10. Consider expertise, steps, and ambiguity.\n"
                    f"Step 3: Identify the primary capability needed: coding, data_analysis, or writing.\n"
                    f"Step 4: Set base_price. Complexity 1-3 → 0.0005-0.002; 4-7 → 0.002-0.005; 8-10 → 0.005-0.009.\n"
                    f"Adjust slightly based on market hint and budget.\n\n"
                    f"Output ONLY valid JSON with your own values:\n"
                    f'{{"base_price": 0.003, "primary_capability": "writing", "complexity": "Mid", "reasoning": "Explain your score."}}'
                )},
            ],
        )
        bank_data = local_parse_json(resp.choices[0].message.content)
        bank_data["task_preview"] = request.description[:50]
        print(f"🧠 Orchestrator: {bank_data}")
    except Exception as e:
        print(f"❌ Orchestrator error: {e}")
        bank_data = {
            "base_price": base_price_hint,
            "primary_capability": "writing",
            "complexity": "Low",
            "task_preview": request.description[:50]
        }
        bank_data = local_parse_json(resp.choices[0].message.content)
        bank_data["task_preview"] = request.description[:50]
        print(f"🧠 Orchestrator: {bank_data}")
        formal_spec = await generate_formal_specification("price_setting", bank_data)
        bank_data["formal_specification"] = formal_spec[:200]
    except Exception as e:
        print(f"❌ Orchestrator error: {e}")
        bank_data = {
            "base_price": economic_forecast.get("recommended_base_price", 0.0015),
            "primary_capability": "coding",
            "complexity": "Low",
            "task_preview": request.description[:50]
        }
    
    # Phase 2: Principled Negotiation (OANP)
    negotiation_results = await negotiate_bids_oanp(
        task=request.description,
        base_price=bank_data["base_price"],
        max_rounds=3
    )
    
    bids = []
    for item in negotiation_results:
        agent_name = item["agent"]
        agent = AGENTS[agent_name]
        bids.append({
            "agent": agent_name,
            "model": agent["model"],
            "host": agent["host"],
            "bid_usdc": item["bid_usdc"],
            "reputation": agent["reputation"],
            "capabilities": agent["capabilities"],
            "interests": item.get("interests", {}),
            "wallet_id": agent["wallet_id"],
            "address": agent["address"],
        })
    
        # Phase 3: Execute Tasks with All Agents
    agent_results = []
    async with aiohttp.ClientSession() as session:
        for name, agent in AGENTS.items():
            print(f"🤖 Calling {name} ({agent['model']})...")
            await sse_queue.put({
                "event": "agent_start",
                "agent": name,
                "timestamp": datetime.now().isoformat()
            })
            try:
                result = await call_agent(
                    session=session,
                    agent_name=name,
                    agent=agent,
                    prompt=f"Task: {request.description}\n{agent.get('system_prompt', 'Be concise and helpful.')}"
                )
                agent_results.append(result)
                if result.get("status") == "success":
                    print(f"✅ {name} responded successfully")
                    AGENTS[name]["successful_tasks"] += 1
                else:
                    print(f"❌ {name} failed: {result.get('error')}")
                AGENTS[name]["total_tasks"] += 1
                AGENTS[name]["trust_score"] = AGENTS[name]["successful_tasks"] / max(1, AGENTS[name]["total_tasks"])
            except Exception as e:
                print(f"❌ {name} exception: {e}")
                agent_results.append({
                    "agent": name,
                    "status": "failed",
                    "error": str(e),
                    "output": ""
                })
                AGENTS[name]["total_tasks"] += 1
            
            # 🔥 DELAY TO PREVENT CONCURRENCY OVERLAP
            await asyncio.sleep(3)    
    
    # Phase 4: AIVV Multi-Agent Council Validation
    validation_result = await aivv_council_validate(request.description, agent_results, bids)
    quality_scores = validation_result["quality_scores"]
    winner_name = validation_result["winner"]
    user_explanation = validation_result["explanation"]
    
    # Robust winner selection
    winner_candidates = [b for b in bids if b["agent"] == winner_name]
    if not winner_candidates:
        successful = [r["agent"] for r in agent_results if r.get("status") == "success"]
        for name in successful:
            cands = [b for b in bids if b["agent"] == name]
            if cands:
                winner_candidates = cands
                winner_name = name
                break
        if not winner_candidates:
            winner_candidates = bids
            winner_name = bids[0]["agent"]
    winner = winner_candidates[0]
    winner_score = quality_scores.get(winner_name, 75)
    
    # Phase 5: Adversarial Hardening (Red/Blue Team)
    winner_output = next((r["output"] for r in agent_results if r["agent"] == winner_name), "")
    accepted, debate_reasoning, robustness_score = await adversarial_debate(
        request.description, winner_output, winner_name
    )
    if not accepted:
        user_explanation += f" Adversarial review flagged concerns: {debate_reasoning[:100]}..."
        winner_score = int(winner_score * 0.8)
    
    print(f"🏆 Validator selected: {winner_name} (Quality: {winner_score}, Robustness: {robustness_score})")
    
    await sse_queue.put({
        "event": "validation_complete",
        "winner": winner_name,
        "scores": quality_scores,
        "robustness": robustness_score,
        "explanation": user_explanation,
        "timestamp": datetime.now().isoformat()
    })
    
    # Phase 6: Payment & Economic Mechanics
    tx_id = transfer_usdc(
        source_wallet_id=orchestrator_id,
        destination_address=winner["address"],
        amount=winner["bid_usdc"],
        note=f"{winner_name} won contest (quality {winner_score})",
    )
    print(f"💸 Payment tx: {tx_id}")
    
    fee_tx_id = None
    fee_tx_id = None
    if winner["wallet_id"] and treasury_address:
        try:
            platform_fee = await determine_platform_fee(request.description, winner["bid_usdc"], winner_score)
            fee_tx_id = transfer_usdc(
                source_wallet_id=winner["wallet_id"],
                destination_address=treasury_address,
                amount=platform_fee,
                note=f"Dynamic platform fee (quality {winner_score})",
            )
        except Exception as e:
            print(f"⚠️ Fee transfer failed: {e}")

    # ----------------------------------------------------------
    # Phase 7: Quality Bonus (score > 90)
    # ----------------------------------------------------------
    bonus_tx_id = None
    if winner_score > 90:
        try:
            quality_bonus = await determine_quality_bonus(request.description, winner["bid_usdc"], winner_score)
            bonus_tx_id = transfer_usdc(
                source_wallet_id=orchestrator_id,
                destination_address=winner["address"],
                amount=quality_bonus,
                note=f"Dynamic quality bonus (score={winner_score})",
            )
        except Exception as e:
            print(f"⚠️ Bonus transfer failed: {e}")

    # ----------------------------------------------------------
    # Phase 8: Slashing (score < 60)
    # ----------------------------------------------------------
    slash_tx_id = None
    if winner_score < 60:
        slash_amount, rep_penalty = await determine_slash_penalty(request.description, winner["bid_usdc"], winner_score)
        try:
            slash_tx_id = transfer_usdc(
                source_wallet_id=winner["wallet_id"],
                destination_address=treasury_address,
                amount=slash_amount,
                note=f"Dynamic slash penalty (quality {winner_score})",
            )
            AGENTS[winner_name]["reputation"] = max(30, AGENTS[winner_name]["reputation"] - rep_penalty)
            print(f"🔻 Slashed {winner_name} reputation by {rep_penalty} to {AGENTS[winner_name]['reputation']}")
        except Exception as e:
            print(f"⚠️ Slash transfer failed: {e}")

    credential_tx_id = None
    if winner_score > 80:
        credential_tx_id = issue_erc8004_credential(AGENTS[winner_name]["address"], winner_score)
    
    txn_count = sum(1 for t in [tx_id, fee_tx_id, bonus_tx_id, slash_tx_id, credential_tx_id] if t)
    
    log_entry = {
        "task": request.description[:60],
        "primary_capability": bank_data.get("primary_capability"),
        "complexity": bank_data.get("complexity"),
        "winner": winner_name,
        "amount_usdc": winner["bid_usdc"],
        "quality_score": winner_score,
        "robustness_score": robustness_score,
        "tx_id": tx_id,
        "fee_tx_id": fee_tx_id,
        "bonus_tx_id": bonus_tx_id,
        "slash_tx_id": slash_tx_id,
        "credential_tx_id": credential_tx_id,
        "on_chain_txns": txn_count,
        "explorer": f"https://testnet.arcscan.app/tx/{tx_id}" if tx_id else None,
        "validator_explanation": user_explanation,
        "formal_specification": bank_data.get("formal_specification", ""),
    }
    transaction_log.append(log_entry)
    
    await database.log_transaction(log_entry)
    await database.update_agent_reputation(
        agent_name=winner_name,
        reputation=AGENTS[winner_name]["reputation"],
        earned_usdc=winner["bid_usdc"]
    )
    
    await sse_queue.put({
        "event": "task_complete",
        "winner": winner_name,
        "amount": winner["bid_usdc"],
        "tx_id": tx_id,
        "explanation": user_explanation,
        "timestamp": datetime.now().isoformat()
    })
    
    return {
        "status": "success",
        "task": request.description,
        "orchestrator_model": ORCHESTRATOR_MODEL,
        "phase_1_analysis": bank_data,
        "phase_2_negotiation": negotiation_results,
        "phase_3_all_outputs": agent_results,
        "phase_4_council_validation": validation_result,
        "phase_5_adversarial": {"accepted": accepted, "reasoning": debate_reasoning, "robustness_score": robustness_score},
        "phase_6_payments": {
            "winner_payment": tx_id,
            "fee": fee_tx_id,
            "bonus": bonus_tx_id,
            "slash": slash_tx_id,
            "credential": credential_tx_id,
        },
        "user_explanation": user_explanation,
        "on_chain_txns_this_task": txn_count,
        "total_txns_so_far": sum(e["on_chain_txns"] for e in transaction_log),
    }

