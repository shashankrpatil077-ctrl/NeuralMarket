                Analyze the last 20 transactions and forecast demand for the next hour.
                Recommend a base_price between 0.0005 and 0.009 USDC.
                
                Transactions: {json.dumps(past[-20:])}
                
                Output JSON: {{"predicted_demand": "low/medium/high", "recommended_base_price": 0.0015, "reasoning": "..."}}
                """
                resp = aiml_client.chat.completions.create(
                    model=ECONOMIST_MODEL,
                    messages=[{"role": "user", "content": prompt}],
                    temperature=0.3,
                )
                economic_forecast = local_parse_json(resp.choices[0].message.content)
                last_forecast_time = datetime.now()
                print(f"📊 Economic forecast updated: {economic_forecast}")
        except Exception as e:
            print(f"Economic forecaster error: {e}")
        await asyncio.sleep(3600)

