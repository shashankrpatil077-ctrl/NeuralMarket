AGENT_SECRETS = {
    "Ash": os.getenv("ASH_SECRET", hashlib.sha256(os.urandom(32)).hexdigest()),
    "GreyNinja": os.getenv("GREYNINJA_SECRET", hashlib.sha256(os.urandom(32)).hexdigest()),
    "TwinSwift": os.getenv("TWINSWIFT_SECRET", hashlib.sha256(os.urandom(32)).hexdigest()),
    "ORCHESTRATOR": os.getenv("ORCHESTRATOR_SECRET", hashlib.sha256(os.urandom(32)).hexdigest()),
    "VALIDATOR": os.getenv("VALIDATOR_SECRET", hashlib.sha256(os.urandom(32)).hexdigest()),
}

def sign_message(agent_name: str, message: str) -> str:
    secret = AGENT_SECRETS.get(agent_name, "").encode()
    return hmac.new(secret, message.encode(), hashlib.sha256).hexdigest()

def verify_signature(agent_name: str, message: str, signature: str) -> bool:
    expected = sign_message(agent_name, message)
    return hmac.compare_digest(expected, signature)

