# OANP Principled Negotiation (Interest-Based)
# ==========================================
async def negotiate_bids_oanp(task: str, base_price: float, max_rounds: int = 3) -> List[Dict[str, Any]]:
    negotiation_history = []
    current_bids = {}
    initial_reasoning = {}
    agent_interests = {}
    final_status = {name: False for name in AGENTS}

    # --- Autonomous Initial Bidding Phase ---
    for name, agent in AGENTS.items():
        prompt = f"""
You are {name}, an autonomous agent with capabilities: {agent['capabilities']}.
Reputation: {agent['reputation']}/100.

Task: "{task}"
Market reference price: ${base_price:.6f} USDC

Based on your unique expertise, the task requirements, and your current reputation, propose your initial bid.
Consider:
- If the task aligns well with your capabilities, you might bid competitively.
- If you have a high reputation, you can charge a premium.
- You may also bid slightly higher or lower depending on your strategy.

Respond ONLY with a JSON object:
{{
    "proposed_bid": {base_price:.6f},
    "reasoning": "Brief justification for your bid"
}}
"""
        resp = aiml_client.chat.completions.create(
            model=AGENT_NEGOTIATION_MODEL,
            messages=[{"role": "user", "content": prompt}],
            temperature=0.7,
        )
        try:
            data = local_parse_json(resp.choices[0].message.content)
            proposed_bid = float(data.get("proposed_bid", base_price))
            proposed_bid = max(0.0001, min(proposed_bid, base_price * 2))
        except Exception:
            proposed_bid = base_price

        current_bids[name] = round(proposed_bid, 6)
        initial_reasoning[name] = data.get("reasoning", "No reasoning provided")
        print(f"  💰 {name} initial bid: ${current_bids[name]:.6f}")
    
    await sse_queue.put({
        "event": "negotiation_start",
        "task": task,
        "base_price": base_price,
        "timestamp": datetime.now().isoformat()
    })
    
    for round_num in range(1, max_rounds + 1):
        print(f"\n--- Principled Negotiation Round {round_num} ---")
        
        for name, agent in AGENTS.items():
            if final_status[name]:
                continue
                
            context = "\n".join(negotiation_history[-10:]) if negotiation_history else "No prior discussion."
            
            prompt = f"""
            You are {name}, an autonomous agent with capabilities: {agent['capabilities']}.
            Reputation: {agent['reputation']}/100.
            
            Task: "{task}"
            Current bids: {json.dumps(current_bids)}
            History: {context}
            
            Your turn in principled negotiation (Harvard method):
            1. State your underlying INTERESTS (e.g., "I want to maximize profit", "I want to build reputation").
            2. State your BATNA (Best Alternative to a Negotiated Agreement).
            3. Propose a bid that creates value for both you and the client.
            4. You may adjust your bid, make a counter-offer, or declare final.
            
            Output JSON:
            {{
                "interests": "I seek to maximize profit while maintaining reputation.",
                "batna": "If I don't win, I will pursue other high-value tasks.",
                "message": "Your statement to other agents.",
                "new_bid": {current_bids[name]:.6f},
                "final": false
            }}
            """
            
            resp = aiml_client.chat.completions.create(
                model=AGENT_NEGOTIATION_MODEL,
                messages=[{"role": "user", "content": prompt}],
                temperature=0.7,
            )
            
            try:
                data = local_parse_json(resp.choices[0].message.content)
                interests = data.get("interests", "")
                batna = data.get("batna", "")
                message = data.get("message", f"I bid {current_bids[name]:.6f} USDC")
                new_bid = float(data.get("new_bid", current_bids[name]))
                is_final = data.get("final", False)
                agent_interests[name] = {"interests": interests, "batna": batna}
            except:
                message = f"I maintain my bid at {current_bids[name]:.6f} USDC"
                new_bid = current_bids[name]
                is_final = False
            
            current_bids[name] = new_bid
            final_status[name] = is_final
            
            entry = f"{name}: {message} (Bid: ${new_bid:.6f})"
            negotiation_history.append(entry)
            print(f"  {entry}")
            
            await sse_queue.put({
                "event": "agent_speak",
                "round": round_num,
                "agent": name,
                "message": message,
                "bid": new_bid,
                "interests": agent_interests.get(name, {}).get("interests", ""),
                "final": is_final,
                "timestamp": datetime.now().isoformat()
            })
        
        if all(final_status.values()):
            break
    
    final_bids = []
    for name, agent in AGENTS.items():
        final_bids.append({
            "agent": name,
            "bid_usdc": current_bids[name],
            "interests": agent_interests.get(name, {}),
            "reputation": agent["reputation"],
            "capabilities": agent["capabilities"],
        })
    
    await sse_queue.put({
        "event": "negotiation_complete",
        "final_bids": final_bids,
        "history": negotiation_history,
        "timestamp": datetime.now().isoformat()
    })
    
    return final_bids

